PORT=5000
PUBLIC_BASE_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d
BCRYPT_ROUNDS=10
API_RATE_LIMIT=300
PAYMENT_RATE_LIMIT=30

DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=broadband_db

# Railway MySQL also works with its built-in MYSQLHOST, MYSQLPORT,
# MYSQLUSER, MYSQLPASSWORD, and MYSQLDATABASE variables.
MYSQLHOST=your-railway-mysql-host
MYSQLPORT=your-railway-mysql-port
MYSQLUSER=your-railway-mysql-user
MYSQLPASSWORD=your-railway-mysql-password
MYSQLDATABASE=your-railway-mysql-database

RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-app-password
SMTP_FROM=NetWave <your-smtp-user>
TEST_EMAIL_TO=your-test-recipient@example.com

WHATSAPP_API_VERSION=v20.0
WHATSAPP_PHONE_NUMBER_ID=your-meta-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-meta-access-token

SMS_API_URL=
SMS_API_KEY=
SMS_FROM=NetWave

# MSG91 SMS. Preferred for India production SMS.
# Create an MSG91 SMS Flow/Template, complete DLT setup, then add these in Render.
MSG91_AUTHKEY=your-msg91-authkey
MSG91_FLOW_ID=your-msg91-flow-id
MSG91_SENDER=NETWAV
MSG91_MESSAGE_VAR=message

# Twilio SMS alternative. Use this instead of SMS_API_URL/SMS_API_KEY.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+91XXXXXXXXXX
TWILIO_MESSAGING_SERVICE_SID=
TEST_SMS_TO=+91XXXXXXXXXX

BILL_DOWNLOAD_SECRET=change-this-bill-link-secret
BILL_DOWNLOAD_TTL_HOURS=168
